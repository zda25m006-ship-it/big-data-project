# Copy to .env before running: cp .env.example .env
PROJECT_NAME=ride-demand

# Kafka
KAFKA_BOOTSTRAP_HOST=localhost:9092
KAFKA_BOOTSTRAP_DOCKER=kafka:29092
KAFKA_TOPIC=ride_events

# MinIO / S3
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=bigdata123
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=bigdata123
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
S3_ENDPOINT=http://minio:9000
S3_BUCKET=ride-demand-lakehouse

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# API and website
API_URL=http://api:3000
LOCAL_API_URL=http://localhost:3000
MODEL_PATH=/app/model_artifacts/model.json
